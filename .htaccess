Options -Indexes
AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Movie slug: /movie/title-year-movie
    RewriteRule ^movie/([a-z0-9-]+)$ /movie.php?slug=$1 [L,QSA]
    # Series slug: /series/title-year-series
    RewriteRule ^series/([a-z0-9-]+)$ /series.php?slug=$1 [L,QSA]
    # Protect includes
    RewriteRule ^includes/ - [F,L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
